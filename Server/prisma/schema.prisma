generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userName  String   @unique
  email     String   @unique
  password  String?
  post      Post[]
  avatar   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Post {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  price      Int
  images    String[]
  address    String
  city       String
  bedrooms   Int
  bathrooms  Int
  latitude   String
  longitude  String

  type       Type
  property   Property

  user       User @relation(fields: [userId], references: [id])
  userId     String @db.ObjectId

  createdAt  DateTime @default(now())
  postDetails PostDetails?

  @@map("Post")
}

enum Type {
  buy
  rent
}

enum Property {
  house
  apartment
  condo
  land
}

model PostDetails {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  des        String
  utilities  String
  pet        String
  income     Int
  size       Int
  school     Int
  bus        Int
  restaurant Int

  post       Post @relation(fields: [postId], references: [id])
  postId     String @db.ObjectId @unique

  @@map("post_details")
}